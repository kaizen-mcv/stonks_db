# Conexion a PostgreSQL
# Formato: postgresql+psycopg://USUARIO:PASSWORD@HOST:PUERTO/DB
# Ejemplo local (peer auth): postgresql+psycopg://tu_usuario@/stonks_db
STONKS_DB_URL=postgresql+psycopg://USER@localhost:5432/stonks_db

# API keys (opcional, pero mejora rate limits)
# FRED: https://fred.stlouisfed.org/docs/api/api_key.html
STONKS_FRED_API_KEY=

# Alpha Vantage: https://www.alphavantage.co/support/#api-key
STONKS_ALPHA_VANTAGE_KEY=

# CoinGecko demo key: https://www.coingecko.com/en/api/pricing
STONKS_COINGECKO_KEY=
